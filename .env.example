# Port d'écoute du serveur (défaut : 7011)
PORT=7011

# Interface d'écoute (défaut : 0.0.0.0)
HOST=0.0.0.0

# URL publique du serveur (recommandé derrière un reverse proxy HTTPS)
# Exemple : https://stremio-pastebin.example.com
BASE_URL=

# Secret de session (obligatoire en production, min. 32 caractères)
# Exemple : openssl rand -hex 32
SESSION_SECRET=

# Environnement Node.js
NODE_ENV=production

# Nombre de proxies devant le serveur (1 pour Caddy/nginx, 0 ou false en local)
# Ne pas utiliser "true" — express-rate-limit le refuse pour des raisons de sécurité.
TRUST_PROXY=1

# Clé API AllDebrid (optionnel si configurée via l'interface web)
ALLDEBRID_API_KEY=

# URL de base des pastes bruts (optionnel si configurée via l'interface web)
# Exemple : https://paste.example.com/raw/
PASTEBIN_BASE_URL=

# Clé API TMDB (optionnel, une clé publique par défaut est utilisée)
TMDB_API_KEY=

# Identifiants admin initiaux (uniquement à la création de users.json)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
